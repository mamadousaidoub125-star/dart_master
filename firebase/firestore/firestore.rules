rules_version = '2';

// Règles de sécurité Firestore pour Dart Master.
//
// Principe directeur : le client (l'app Flutter) ne doit JAMAIS pouvoir
// écrire directement des champs sensibles à la triche (score de match,
// classement, monnaie virtuelle). Ces écritures passent obligatoirement
// par des Cloud Functions (voir firebase/functions/src/index.js) qui
// valident la cohérence des données côté serveur avant d'écrire.
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Profils utilisateurs ---
    match /users/{userId} {
      allow read: if request.auth != null;
      // Le joueur ne peut modifier que des champs cosmétiques/non sensibles
      // de son propre profil (pseudo, avatar, préférences). Les champs
      // coins/diamonds/xp/level sont exclus et gérés uniquement côté serveur.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['coins', 'diamonds', 'xp', 'level', 'isPremium']);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Suppression de compte gérée via Cloud Function dédiée (RGPD).
    }

    // --- Historique des parties (lecture seule côté client) ---
    match /matches/{matchId} {
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.playerIds);
      allow write: if false; // Écrit uniquement par la Cloud Function validateMatchResult.
    }

    // --- Classements (lecture publique, écriture serveur uniquement) ---
    match /leaderboards/{leaderboardId}/entries/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Amis et invitations ---
    match /friendships/{friendshipId} {
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.participantIds);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participantIds;
    }

    // --- Messages de chat (entre amis ou dans une partie) ---
    match /chats/{chatId}/messages/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500; // Anti-spam basique.
      allow update, delete: if false;
    }

    // --- Tournois ---
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if false; // Géré par Cloud Functions (création de bracket, avancement des rounds).
    }

    // --- Inventaire cosmétique (fléchettes, cibles, avatars débloqués) ---
    match /inventories/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Déverrouillage uniquement via Cloud Function (achat validé ou récompense).
    }
  }
}
